{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2023",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations": "6.0",

    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "skipLibCheck": true
  }
}
